# ============================================================
# AJ Pronos — Mobile (Expo) · Template variables
# ============================================================
# Copie en .env.local et remplis avec les vraies valeurs.
# Tout ce qui commence par EXPO_PUBLIC_ est exposé au bundle JS.
# NE COMMITE JAMAIS .env.local.
# ============================================================

# ---------- Supabase ----------
# Dashboard → Settings → API (les mêmes valeurs que app/.env.local)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ---------- App config ----------
EXPO_PUBLIC_APP_NAME=AJ Pronos
