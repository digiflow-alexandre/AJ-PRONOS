{
  "expo": {
    "name": "AJ Pronos",
    "slug": "aj-pronos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aj-pronos",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "fr.ajpronos.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Pour ajouter une photo de profil ou partager un screenshot de ticket bookmaker.",
        "NSPhotoLibraryUsageDescription": "Pour choisir une photo de profil ou un screenshot de ticket bookmaker.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "fr.ajpronos.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["NOTIFICATIONS"]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0A",
          "image": "./assets/images/aj-pronos-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/aj-pronos-logo.png",
            "imageWidth": 220
          }
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
