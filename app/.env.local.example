# ============================================================
# AJ Pronos — App SaaS · Template variables d'environnement
# ============================================================
# Copie ce fichier en .env.local et remplis les valeurs réelles.
# NE COMMITE JAMAIS .env.local (déjà dans .gitignore).
# ============================================================

# ---------- Supabase ----------
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...  # côté serveur uniquement, JAMAIS exposée client

# ---------- Stripe ----------
# Dashboard → Developers → API keys (mode test au démarrage)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # générée quand on crée le webhook
# Price IDs (à créer dans Stripe Dashboard → Products)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_VIP_MONTHLY=price_...
STRIPE_PRICE_VIP_YEARLY=price_...

# ---------- Resend (emails transactionnels) ----------
# Dashboard → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@ajpronos.fr

# ---------- API-Football (RapidAPI) ----------
# rapidapi.com → API-Football → Subscribe (free tier)
API_FOOTBALL_KEY=...
API_FOOTBALL_HOST=v3.football.api-sports.io

# ---------- Anthropic Claude API ----------
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ---------- App config ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000  # changera en https://app.ajpronos.fr en prod
NEXT_PUBLIC_SITE_URL=http://localhost:3002  # vitrine, pour les liens retour
CRON_SECRET=  # chaîne aléatoire (32 chars) pour sécuriser les routes /api/cron/*
